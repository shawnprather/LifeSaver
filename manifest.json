{
  "name": "LifeSaver",
  "description": "Save your life from the addiction of youtube whilst still being able to enjoy and learn about important topics",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": ["storage", "tabs"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/settings.html",
    "default_icon": "assests/icon.jpg"
  }
}
